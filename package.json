{
  "name": "webcam",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "check": "pnpm run typecheck && pnpm run lint && pnpm run format:check",
    "dev": "wrangler dev --tunnel",
    "cf-typegen": "wrangler types",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "lint": "oxlint src --tsconfig tsconfig.json --deny-warnings",
    "lint:fix": "oxlint src --tsconfig tsconfig.json --fix",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@types/qrcode": "^1.5.6",
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "@oxfmt/binding-linux-x64-gnu": "0.49.0",
    "@oxlint/binding-linux-x64-gnu": "1.59.0",
    "@types/node": "^25.9.1",
    "oxfmt": "^0.49.0",
    "oxlint": "^1.59.0",
    "typescript": "^5.5.2",
    "wrangler": "^4.95.0"
  }
}
